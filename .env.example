# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values before running.
# NEVER commit the real .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=azimute
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=azimute_db

# ── Prisma (used by apps/api) ────────────────────────────────────────────────
# Development (apps run natively): host = localhost
# Production  (Docker Compose):    host = postgres  (service name)
DATABASE_URL=postgresql://azimute:changeme_strong_password@localhost:5432/azimute_db

# ── Redis (used by apps/api) ─────────────────────────────────────────────────
# Development: localhost  |  Production (Docker): redis
REDIS_URL=redis://localhost:6379

# ── API (apps/api) ───────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000

# Secret for signing JWT tokens (min 32 chars, run: openssl rand -hex 32)
JWT_SECRET=changeme_32_chars_minimum_please_replace_this

# JWT expiration
JWT_EXPIRES_IN=7d

# ── Auth.js / NextAuth (apps/web) ────────────────────────────────────────────
# Same value as JWT_SECRET (or different — both must be set)
AUTH_SECRET=changeme_32_chars_minimum_please_replace_this

# Public URL of the web app (no trailing slash)
# Development:  http://localhost:3000
# Raspberry Pi: http://192.168.4.1
NEXTAUTH_URL=http://localhost:3000

# ── Web public env vars (embedded at build time by Next.js) ──────────────────
# These MUST be set before `docker compose build` for production images.
# Development: point to localhost  |  Raspberry Pi: point to 192.168.4.1

# Base URL of the REST API (no trailing slash, no /api prefix)
NEXT_PUBLIC_API_URL=http://localhost/api

# Base URL for Socket.io connection
NEXT_PUBLIC_WS_URL=http://localhost

# ── Media uploads ─────────────────────────────────────────────────────────────
# Absolute path on the host where uploaded files are stored.
# In Docker this maps to the `uploads` named volume.
UPLOADS_PATH=/app/uploads

# Max file sizes (in bytes)
UPLOAD_MAX_IMAGE_SIZE=5242880   # 5 MB
UPLOAD_MAX_VIDEO_SIZE=52428800  # 50 MB

# ── Game settings ─────────────────────────────────────────────────────────────
# Redis key TTL for an active game session (seconds) — 4 hours
GAME_SESSION_TTL=14400

# Max WebSocket events per second per socket connection
GAME_WS_RATE_LIMIT=10
